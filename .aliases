# ~/.aliases - ultimate text-surgery aliases/functions for bash or zsh

# Prevent existing aliases from breaking function definitions in zsh
unalias ff fdext fdir rgi rgf rgc rgctx todo sdrun sdall sdrxrun sdrxall trimfiles freq words sumcol avgcol topfield rxonly jpp jpick csvview ws1 lower upper snake cutc between untilpat splitby catuniq intersect commdiff cbcopy cbpaste brightness fdcount fdsize fddel rgurl rgip rgemail glogf gchange gpr grem gloc gstas gcon gignore diffstat diffword csvjoin csvdedup csvsort csvcol csvstats csvslice jsonvalid jsonflat jsonwalk b64enc b64dec urlenc urldec hexencode hexdecode camel kebab title batchrn batchcp batchchmod batchconvert batchresize dedupfiles deduplines tarc tarx tarl portscan fastscan listenports detectservices netinfo myip myips dnscheck dnsptr dnsmail httpstatus httpheader httpbody apicheck apiscan cookiecheck headcheck csrfcheck sslcheck ssltest recon-audit recon-webcheck sec-status sec-tools suspicious analyze stringsx hexview entropy cmpbin peek exif genpass genpass-simple genuuid totp hash hashall crypt decrypt seal unseal gpg-enc gpg-dec logcheck secwatch sudocheck lastlogins mkcd hist histn extract here cheat epoch count size findtext colors path fm paint sysinfo sysdisk sysmem syscpu sysuptime systemp procs prockill proctop procmon 2>/dev/null

# ──[ System & Process ]────────────────────────────────────────────

# Example: sysinfo
sysinfo() {
  printf 'Kernel: %s\n' "$(uname -r)"
  printf 'Hostname: %s\n' "$(hostname)"
  printf 'Uptime: '
  uptime
  if command -v lscpu >/dev/null 2>&1; then
    printf 'CPU: %s\n' "$(lscpu | awk -F': +' '/Model name/ {print $2}')"
  else
    printf 'CPU: %s\n' "$(awk -F': ' '/model name/ {print $2; exit}' /proc/cpuinfo)"
  fi
  free -h | awk '/^Mem:/ {printf "Memory: %s / %s\n", $3, $2}'
}

# Example: sysdisk
sysdisk() {
  df -h "$@" | rg -v 'tmpfs|devtmpfs|squashfs|overlay'
}

# Example: sysmem
sysmem() {
  free -h
}

# Example: syscpu
syscpu() {
  if command -v lscpu >/dev/null 2>&1; then
    lscpu | rg -E 'Model name|^CPU\(s\)|Core|Thread|Architecture|MHz'
  else
    awk -F': ' '/model name|cpu cores|siblings|cpu MHz/ {print $1 ": " $2; exit}' /proc/cpuinfo
  fi
}

# Example: sysuptime
sysuptime() {
  if command -v uptime >/dev/null 2>&1; then
    uptime
  else
    cat /proc/uptime | awk '{printf "%d days %d hours %d minutes\n", $1/86400, ($1%86400)/3600, ($1%3600)/60}'
  fi
}

# Example: systemp
systemp() {
  if command -v sensors >/dev/null 2>&1; then
    sensors | rg -E 'Core|Package|Tctl|Tdie' || sensors
  else
    printf 'sensors not found. Install: sudo pacman -S lm_sensors\n' >&2
    return 127
  fi
}

# Example: procs firefox
procs() {
  [ "$#" -ge 1 ] || { printf 'usage: procs NAME\n' >&2; return 2; }
  ps aux | rg -i "$1" | rg -v "rg.*$1"
}

# Example: prockill firefox
prockill() {
  [ "$#" -ge 1 ] || { printf 'usage: prockill NAME\n' >&2; return 2; }
  pkill -f "$1"
}

# Example: proctop cpu
proctop() {
  [ "$#" -ge 1 ] || { printf 'usage: proctop cpu|mem\n' >&2; return 2; }
  case "$1" in
    cpu) ps aux --sort=-%cpu | head -20 ;;
    mem) ps aux --sort=-%mem | head -20 ;;
    *) printf 'usage: proctop cpu|mem\n' >&2; return 2 ;;
  esac
}

# Example: procmon firefox
procmon() {
  [ "$#" -ge 1 ] || { printf 'usage: procmon NAME\n' >&2; return 2; }
  if command -v watch >/dev/null 2>&1; then
    watch -n 1 "ps aux | rg '$1' | rg -v 'rg.*$1'"
  else
    printf 'watch not found. Install: sudo pacman -S procps-ng\n' >&2
    return 127
  fi
}

# ──[ Display ]─────────────────────────────────────────────────────

alias fps_60="xrandr --output eDP --mode 2560x1600 --rate 60"

alias dual_monitor='
rate=$(xrandr | awk "/^HDMI-1-0 connected/{f=1} f && /3840x2160/{for(i=2;i<=NF;i++){gsub(/[^0-9.]/,\"\",\$i); if(\$i>max) max=\$i}} END{print max}");
xrandr --output eDP --primary --auto --pos 0x0 --rotate normal \
       --output HDMI-1-0 --mode 3840x2160 --rate $rate --right-of eDP --rotate normal &&
echo "Dual monitor active – 4K @$rate Hz"
'

alias external_only='
rate=$(xrandr | awk "/^HDMI-1-0 connected/{f=1} f && /3840x2160/{for(i=2;i<=NF;i++){gsub(/[^0-9.]/,\"\",\$i); if(\$i>max) max=\$i}} END{print max}");
xrandr --output eDP --off \
       --output HDMI-1-0 --primary --mode 3840x2160 --rate $rate --pos 0x0 --rotate normal &&
i3-msg "workspace 1; move workspace to output HDMI-1-0" &&
echo "External-only monitor active – 4K @$rate Hz"
'

alias internal_only='
rate=$(xrandr | awk "/^eDP connected/{f=1} f && /2560x1600/{for(i=2;i<=NF;i++){gsub(/[^0-9.]/,\"\",\$i); if(\$i>max) max=\$i}} END{print max}");
xrandr --output HDMI-1-0 --off \
       --output eDP --primary --mode 2560x1600 --rate $rate --pos 0x0 --rotate normal &&
i3-msg "workspace 1; move workspace to output eDP" &&
echo "Laptop-only mode active – 2560x1600 @$rate Hz"
'

# Example: brightness 0.8
brightness() {
  xrandr --output eDP --brightness "$1" \
         --output HDMI-1-0 --brightness "$1"
}

