alias gclean="git clean -fd"
alias gprune="git fetch -p && git branch --merged | grep -v '\\*' | xargs -n 1 git branch -d"

# Example: glogf src/main.rs
glogf() {
  [ "$#" -ge 1 ] || { printf 'usage: glogf FILE\n' >&2; return 2; }
  git log --oneline -- "$1"
}

# Example: gchange
gchange() {
  git diff --name-only HEAD~5..HEAD | sort -u
}

# Example: gpr 42
gpr() {
  [ "$#" -ge 1 ] || { printf 'usage: gpr PR_NUMBER\n' >&2; return 2; }
  git fetch origin "pull/$1/head:pr-$1" && git switch "pr-$1"
}

# Example: grem
grem() {
  git remote -v
}

# Example: gloc
gloc() {
  if command -v cloc >/dev/null 2>&1; then
    cloc .
  elif command -v tokei >/dev/null 2>&1; then
    tokei .
  elif command -v sloccount >/dev/null 2>&1; then
    sloccount .
  else
    git ls-files 2>/dev/null | xargs wc -l 2>/dev/null | tail -1 || printf 'Not a git repo or no files\n' >&2
  fi
}

# Example: gstas
gstas() {
  git stash list --date=short --format='%gd: %gs (%ai)'
}

# Example: gcon
gcon() {
  git shortlog -sn --all
}

# Example: gignore '*.log'
gignore() {
  [ "$#" -ge 1 ] || { printf 'usage: gignore PATTERN\n' >&2; return 2; }
  printf '%s\n' "$1" >> .gitignore
}

# Example: diffstat
diffstat() {
  git diff --stat "$@"
}

# Example: diffword
diffword() {
  git diff --word-diff "$@"
}

