if [ -n "$TMUX" ]; then
  tmux list-panes -a -F "#{pane_id} #{pane_current_command} #{pane_in_mode}" \
  | awk '"'"'$2 ~ /^(bash|zsh|fish|sh)$/ && $3 == 0 { print $1 }'"'"' \
